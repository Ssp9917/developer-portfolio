# MongoDB (required for admin panel)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT secret for admin auth (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Optional: used only for first-time setup via API
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# Cloudinary settings (for image upload in admin panel)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Existing portfolio env vars
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GTM=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_RECAPTCHA_SECRET_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
